# Sendspin Receiver — configuration
# Copier ce fichier vers .env et adapter les valeurs

# Nom affiché sur le serveur Sendspin
SENDSPIN_NAME=Bureau

# Device ALSA (lancer: docker compose run --rm sendspin list-devices)
SENDSPIN_AUDIO_DEVICE=

# URL WebSocket du serveur (laisser vide pour mDNS auto-discovery)
# Exemple: ws://192.168.1.100:8927/sendspin
SENDSPIN_SERVER_URL=

# Format audio préféré, ex: flac:48000:24:2 (laisser vide pour auto-négociation)
SENDSPIN_AUDIO_FORMAT=

# Compensation de latence en ms (souvent négatif)
SENDSPIN_STATIC_DELAY_MS=

# Contrôle du volume hardware (true/false)
SENDSPIN_HARDWARE_VOLUME=true

# Port d'écoute pour les connexions entrantes
SENDSPIN_PORT=8927

# ID unique du client (utile si plusieurs instances sur le même hôte)
SENDSPIN_CLIENT_ID=

# Commandes à exécuter quand le stream démarre/s'arrête
SENDSPIN_HOOK_START=
SENDSPIN_HOOK_STOP=

# Script de contrôle de volume externe (reçoit 0-100 en dernier argument)
SENDSPIN_HOOK_SET_VOLUME=

# Niveau de log : DEBUG, INFO, WARNING, ERROR, CRITICAL
SENDSPIN_LOG_LEVEL=INFO

# GID du groupe audio sur l'hôte (défaut 29 pour Debian/Ubuntu/TrueNAS)
# Vérifier avec: stat -c '%g' /dev/snd/controlC0
AUDIO_GID=29
