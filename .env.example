# Sendspin Receiver — configuration
# Copy this file to .env and adjust the values

# Name shown in the Sendspin app
SENDSPIN_NAME=Sendspin Speaker

# Audio device — leave empty for auto-detection (recommended for single-speaker setups)
# To force a specific device, first run:
#   docker compose run --rm sendspin list-devices
# then set the index [X] of the desired device
SENDSPIN_AUDIO_DEVICE=

# WebSocket server URL — leave empty for mDNS auto-discovery
# Example: ws://192.168.1.100:8927/sendspin
SENDSPIN_SERVER_URL=

# Preferred audio format, e.g. flac:48000:24:2 — leave empty for auto-negotiation
SENDSPIN_AUDIO_FORMAT=

# Latency compensation in ms (often negative)
SENDSPIN_STATIC_DELAY_MS=

# Hardware volume control (true/false)
SENDSPIN_HARDWARE_VOLUME=true

# Listening port for incoming connections
SENDSPIN_PORT=8927

# Unique client ID — useful when running multiple instances on the same host
SENDSPIN_CLIENT_ID=

# Commands to run when the stream starts/stops
SENDSPIN_HOOK_START=
SENDSPIN_HOOK_STOP=

# External volume control script (receives 0-100 as last argument)
SENDSPIN_HOOK_SET_VOLUME=

# Manufacturer name (reported in client hello)
SENDSPIN_MANUFACTURER=

# Product name (reported in client hello, defaults to OS/platform name)
SENDSPIN_PRODUCT_NAME=

# Container version label shown in startup logs
SENDSPIN_DOCKER_VERSION=local

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
SENDSPIN_LOG_LEVEL=INFO

# Audio group GID on the host (default 29 for Debian/Ubuntu/TrueNAS)
# Check with: stat -c '%g' /dev/snd/controlC0
AUDIO_GID=29
